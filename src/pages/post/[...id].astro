---
import { getCollection, render } from "astro:content"
import { formatCategory, formatDateCN } from "@/lib/utils"
import { Badge } from "@/components/ui/badge"
import PostLayout from "@/layouts/post.astro"
import H2 from "@/components/mdx/h2.astro"
import H3 from "@/components/mdx/h3.astro"
import Blockquote from "@/components/mdx/blockquote.astro"
import P from "@/components/mdx/p.astro"
import List from "@/components/mdx/list.astro"
import Table from "@/components/mdx/table/table.astro"
import Th from "@/components/mdx/table/th.astro"
import Tr from "@/components/mdx/table/tr.astro"
import Td from "@/components/mdx/table/td.astro"

const components = {
  h2: H2,
  h3: H3,
  blockquote: Blockquote,
  p: P,
  ul: List,
  table: Table,
  th: Th,
  tr: Tr,
  td: Td,
}

export async function getStaticPaths() {
  const posts = await getCollection("posts")
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
---

<PostLayout>
  <div class="my-16">
    <div class="my-8 flex justify-center">
      <a href={`/post/${post.data.category}/1`}>
        <Badge variant="secondary">{formatCategory(post.data.category)}</Badge>
      </a>
    </div>
    <h1
      class="my-8 scroll-m-20 text-center text-4xl font-extrabold tracking-tight text-balance"
    >
      {post.data.title}
    </h1>
    <p class="my-8 text-center text-xl text-muted-foreground">
      {post.data.subtitle}
    </p>
    <p class="my-8 text-center text-sm text-muted-foreground">
      {formatDateCN(post.data.pubDate)}
    </p>
  </div>
  <blockquote class="my-16 border-l-2 pl-6 italic">
    &quot;{post.data.abstract}&quot;
  </blockquote>
  <Content components={components} />
</PostLayout>
