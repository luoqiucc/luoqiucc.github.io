---
import type { GetStaticPathsOptions } from "astro"
import { getCollection } from "astro:content"
import { PaperCard } from "@/components/paper-card"
import IndexLayout from "@/layouts/index.astro"
import { PostPagination } from "@/components/pagination"

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const papers = await getCollection("posts", ({ data }) => {
    return data.category == "paper"
  })

  return paginate(papers, { pageSize: 12 })
}

const { page } = Astro.props
---

<IndexLayout>
  <h1
    class="my-8 scroll-m-20 text-4xl font-extrabold tracking-tight text-balance"
  >
    论文研读
  </h1>
  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
    {page.data.map((post) => <PaperCard post={post} />)}
  </div>
  <div class="my-8">
    <PostPagination page={page} category="post/paper" />
  </div>
</IndexLayout>
